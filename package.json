{
  "name": "choda-deck",
  "version": "0.1.1",
  "description": "MCP server providing SQLite-backed task/session/conversation orchestration for Claude Code.",
  "author": "Vu Ngo",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "choda-deck": "dist/cli.cjs",
    "mcp-server": "dist/mcp-server.cjs"
  },
  "files": [
    "dist/cli.cjs",
    "dist/mcp-server.cjs",
    "dist/session-rules.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "task-tracking",
    "sqlite",
    "agent-orchestration"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/butterngo/choda-deck.git"
  },
  "homepage": "https://github.com/butterngo/choda-deck#readme",
  "bugs": {
    "url": "https://github.com/butterngo/choda-deck/issues"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "test": "node scripts/test.mjs run",
    "test:watch": "node scripts/test.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json --composite false",
    "build:mcp": "esbuild src/adapters/mcp/server.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/mcp-server.cjs --external:better-sqlite3 --external:sqlite-vec --external:@huggingface/transformers --external:onnxruntime-node --external:onnxruntime-web --external:sharp && node -e \"require('fs').copyFileSync('src/adapters/mcp/rules/session-rules.md','dist/session-rules.md')\"",
    "build:cli": "esbuild src/adapters/cli/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/cli.cjs --external:better-sqlite3 --external:sqlite-vec --external:@huggingface/transformers --external:onnxruntime-node --external:onnxruntime-web --external:sharp",
    "build": "pnpm run build:mcp && pnpm run build:cli",
    "smoke:cli": "pnpm run build:cli && node scripts/smoke-cli.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "sqlite-vec": "^0.1.9"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "onnxruntime-node": "1.24.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "onnxruntime-node",
      "sharp",
      "protobufjs"
    ]
  }
}

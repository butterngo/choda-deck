{
  "name": "choda-deck",
  "version": "0.0.1",
  "description": "Desktop orchestrator for multiple interactive Claude Code sessions — sidebar per project, main pane hosts live PTY-backed xterm.js instances.",
  "main": "./out/main/index.js",
  "author": "Vu Ngo",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "test": "node scripts/test.mjs run",
    "test:watch": "node scripts/test.mjs",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "start": "node scripts/dev.mjs preview",
    "dev": "node scripts/dev.mjs dev",
    "build": "pnpm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:mcp": "esbuild src/adapters/mcp/server.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/mcp-server.cjs --external:better-sqlite3",
    "icons": "node scripts/build-icons.mjs",
    "build:unpack": "pnpm run build && pnpm run build:mcp && electron-builder --dir",
    "build:win": "pnpm run build && pnpm run build:mcp && electron-builder --win",
    "mcp:tasks": "node scripts/mcp-start.mjs"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "mermaid": "^11.14.0",
    "node-pty": "^1.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^29.0.2",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.4"
  }
}
